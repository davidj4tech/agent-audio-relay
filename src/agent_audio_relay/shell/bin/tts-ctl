#!/bin/bash
# TTS playback control via mpv IPC.
# Usage: tts-ctl pause|resume|toggle|replay [session]|seek SECS|start|volume DELTA|mute|slower|faster|speed N|status|nowplaying|get PROP...
#
# Talks to the mpv-tts daemon (Termux service `mpv-tts`) on the phone via
# its JSON-IPC unix socket. When invoked on the phone the socket is hit
# directly; from any other host it tunnels over `ssh $CLAUDE_TTS_PHONE_HOST`.
#
# replay resolves target in this order:
#   1. explicit [session] arg
#   2. current tmux session name
#   3. global latest
set -u
PHONE_HOST="${CLAUDE_TTS_PHONE_HOST:-p8ar}"
# Default to the mpv-backend's archive (XDG_STATE_HOME/agent-audio-relay).
# That's where the running agent-audio-relay service on the phone writes
# clips it played. The legacy `.cache/agent-audio` path was the
# ssh-termux-backend's destination — only relevant in setups that bypass
# the relay service. Override with CLAUDE_TTS_PHONE_ARCHIVE if needed.
ARCHIVE_DIR="${CLAUDE_TTS_PHONE_ARCHIVE:-/data/data/com.termux/files/home/.local/state/agent-audio-relay}"
# Audio extensions to try, in order. Pi-rp/Qwen produces wav; Claude/edge/openai
# produce mp3. The first matching `latest{--session,}.{ext}` wins.
EXTS=(${CLAUDE_TTS_EXT:-wav mp3 opus ogg})
# Socket auto-discovery: prefer an explicit MPV_TTS_SOCK; otherwise use
# the local tunnel socket if `aar-mpv-tunnel` is running (set up by the
# systemd user service); otherwise fall back to the on-phone path. The
# tunnel turns every IPC op into a local socat call (saves ~600ms vs an
# ssh fork) and uses ssh keepalives to keep Tailscale warm.
_default_local_sock="${XDG_STATE_HOME:-$HOME/.local/state}/agent-audio-relay/mpv-tts.sock"
if [ -n "${MPV_TTS_SOCK:-}" ]; then
    SOCK="$MPV_TTS_SOCK"
elif [ -S "$_default_local_sock" ]; then
    SOCK="$_default_local_sock"
else
    SOCK="/data/data/com.termux/files/usr/tmp/mpv-tts.sock"
fi

slug() {
    printf '%s' "$1" | tr -c 'A-Za-z0-9-' '-' | sed 's/-\+/-/g; s/^-//; s/-$//'
}

# Default ssh flags. Timeouts matter most when the phone is asleep —
# without them, the connection sits open and any backgrounded command
# (e.g. popup's `tts-ctl toggle &`) just queues forever, then fires
# minutes later when the next clip emit wakes Tailscale. Fail fast
# instead so the user sees nothing happen and can retry rather than
# getting a delayed replay.
#   ConnectTimeout=5            — initial dial-up budget
#   ServerAliveInterval=3       — keepalive every 3s on active conn
#   ServerAliveCountMax=2       — drop after 2 missed keepalives (~6s)
TTS_SSH_DEFAULTS="-o BatchMode=yes -o ConnectTimeout=5 -o ServerAliveInterval=3 -o ServerAliveCountMax=2"

mpv_cmd() {
    local json="$1"
    if [ -S "$SOCK" ]; then
        printf '%s\n' "$json" | socat - "UNIX-CONNECT:$SOCK" 2>/dev/null
    else
        # shellcheck disable=SC2029,SC2086
        ssh ${TTS_SSH_DEFAULTS} ${CLAUDE_TTS_SSH_OPTS:-} "$PHONE_HOST" \
            "printf '%s\n' $(printf '%q' "$json") | socat - 'UNIX-CONNECT:$SOCK'" \
            2>/dev/null
    fi
}

mpv_get() {
    local prop="$1"
    mpv_cmd "{\"command\":[\"get_property\",\"$prop\"]}" \
        | jq -r 'select(.error=="success") | .data' 2>/dev/null
}

# Batched get: one IPC round-trip for N properties. Echoes one value per
# input prop, in order, on its own line. Empty line for missing/error.
mpv_batch_get() {
    local props=("$@") cmds="" i=1 raw
    for p in "${props[@]}"; do
        cmds+="{\"command\":[\"get_property\",\"$p\"],\"request_id\":$i}"$'\n'
        i=$((i+1))
    done
    if [ -S "$SOCK" ]; then
        raw=$(printf '%s' "$cmds" | socat - "UNIX-CONNECT:$SOCK" 2>/dev/null)
    else
        # shellcheck disable=SC2029,SC2086
        raw=$(ssh ${TTS_SSH_DEFAULTS} ${CLAUDE_TTS_SSH_OPTS:-} "$PHONE_HOST" \
            "printf '%s' $(printf '%q' "$cmds") | socat - 'UNIX-CONNECT:$SOCK'" \
            2>/dev/null)
    fi
    for ((i=1; i<=${#props[@]}; i++)); do
        # Emit exactly one line per prop (empty if unavailable) so callers
        # using mapfile keep stable indices.
        local val
        val=$(printf '%s\n' "$raw" \
            | jq -r --argjson rid "$i" \
                'select(.request_id==$rid and .error=="success") | .data' 2>/dev/null \
            | head -n1)
        printf '%s\n' "$val"
    done
}

host_slug() {
    hostname -s 2>/dev/null \
        | tr 'A-Z' 'a-z' \
        | tr -c 'a-z0-9-' '-' \
        | sed 's/-\+/-/g; s/^-//; s/-$//'
}

replay_target() {
    local session="$1"
    if [ -z "$session" ] && [ -n "${TMUX_PANE:-}" ]; then
        session=$(tmux display-message -p -t "$TMUX_PANE" '#{session_name}' 2>/dev/null)
    fi
    # Build candidate stems in priority order. Host-prefixed first so two
    # hosts with the same session name don't pick up each other's clip via
    # the shared latest--<session> symlink on the phone.
    local candidates=() sslug hslug
    if [ -n "$session" ]; then
        sslug=$(slug "$session")
        hslug=$(host_slug)
        [ -n "$hslug" ] && candidates+=("$ARCHIVE_DIR/latest--$hslug--$sslug")
        candidates+=("$ARCHIVE_DIR/latest--$sslug")
    fi
    # No global `latest` fallback by design — replaying a clip from another
    # host/session is the bug session-pinning was added to fix. With no
    # session and no candidates, the synthetic path below makes mpv error
    # out visibly rather than silently misroute.
    # Prefer a remote-existing match; mpv loadfile of a missing path is
    # a silent no-op, which is worse UX than picking *something* and
    # letting mpv error out visibly.
    #
    # Probe order:
    #   1. The candidate symlinks (`latest--<host>--<session>` then
    #      `latest--<session>`) — fast, deterministic, handles current
    #      cross-session collisions.
    #   2. Glob fallback for historical clips that pre-date the per-session
    #      symlink writes: most-recent `*--<session>__*.<ext>` by mtime.
    # `[ -S "$SOCK" ]` was the local-vs-remote discriminator before the
    # ssh tunnel existed; with it, SOCK is a local-side forwarded socket
    # but ARCHIVE_DIR is still a phone path. Separate the checks: the
    # local filesystem branch only applies when ARCHIVE_DIR actually
    # resolves on this host (i.e. we are the phone).
    if [ -d "$ARCHIVE_DIR" ]; then
        local stem
        for stem in "${candidates[@]}"; do
            for ext in "${EXTS[@]}"; do
                [ -e "$stem.$ext" ] && { printf '%s' "$stem.$ext"; return; }
            done
        done
        if [ -n "$session" ]; then
            local newest ext
            for ext in "${EXTS[@]}"; do
                newest=$(ls -t1 "$ARCHIVE_DIR"/*--"${sslug}"__*."$ext" 2>/dev/null | head -n1)
                [ -n "$newest" ] && { printf '%s' "$newest"; return; }
            done
        fi
    else
        # Single ssh call: probe symlink candidates in priority order, then
        # fall through to a most-recent glob match for the session.
        local probe_script="" stem
        for stem in "${candidates[@]}"; do
            probe_script+="for e in ${EXTS[*]}; do [ -e \"$stem.\$e\" ] && { echo \"$stem.\$e\"; exit 0; }; done; "
        done
        if [ -n "$session" ]; then
            local globs="" ext
            for ext in "${EXTS[@]}"; do
                globs+="$ARCHIVE_DIR/*--${sslug}__*.$ext "
            done
            probe_script+="ls -t1 $globs 2>/dev/null | head -n1"
        fi
        local probe
        # Force bash on the remote so unmatched globs in the fallback don't
        # abort under zsh's default NOMATCH (Termux user shell is often zsh).
        # shellcheck disable=SC2086
        probe=$(ssh ${TTS_SSH_DEFAULTS} ${CLAUDE_TTS_SSH_OPTS:-} "$PHONE_HOST" \
            "bash -c $(printf '%q' "$probe_script")" 2>/dev/null)
        [ -n "$probe" ] && { printf '%s' "$probe"; return 0; }
    fi
    # Nothing matched. Return non-zero with no output so callers can
    # distinguish "no clip exists for this session" from "found one" —
    # firing mpv loadfile on a synthetic non-existent path was worse:
    # mpv either silently no-op'd or unloaded the previous clip,
    # leaving the user mid-action with no audio and no feedback.
    return 1
}

fmt_time() {
    local t="$1"
    if [ -z "$t" ] || [ "$t" = "null" ]; then
        printf -- '--:--'
        return
    fi
    awk -v t="$t" 'BEGIN{ s=int(t); printf "%02d:%02d", s/60, s%60 }'
}

case "${1:-}" in
    pause)   mpv_cmd '{"command":["set_property","pause",true]}'  >/dev/null ;;
    resume)  mpv_cmd '{"command":["set_property","pause",false]}' >/dev/null ;;
    toggle)
        # Reload-or-pause. The user-mental-model for Space in a session-pinned
        # popup is "play my session's clip". Reload whenever:
        #   - mpv is idle (nothing loaded), OR
        #   - mpv is at EOF (clip finished; default keep-open leaves file
        #     loaded but eof-reached=true), OR
        #   - the currently-loaded path doesn't belong to this session.
        # Only flip pause when the right clip is already loaded mid-playback.
        #
        # Latency note: replay_target costs one ssh round-trip to the phone.
        # Skip it when mpv's reported path basename is unambiguously a
        # `latest--…--<session>` symlink for this session — same answer
        # without the probe.
        mapfile -t _state < <(mpv_batch_get idle-active eof-reached path)
        _idle="${_state[0]:-}"
        _eof="${_state[1]:-}"
        _cur="${_state[2]:-}"
        _sess="${2:-}"
        _need_reload=0
        if [ "$_idle" = "true" ] || [ "$_eof" = "true" ] || [ -z "$_cur" ]; then
            _need_reload=1
        elif [ -n "$_sess" ]; then
            _sslug=$(slug "$_sess")
            _curbase="${_cur##*/}"
            case "$_curbase" in
                latest--"$_sslug".*|latest--*--"$_sslug".*|latest--"$_sslug"__*) ;;
                *)
                    # Path doesn't look like a symlink for this session.
                    # Resolve target and compare. If no clip exists for this
                    # session, _target stays empty and we'll fall through to
                    # cycle pause below — better than firing loadfile of a
                    # synthetic path that breaks mpv's state.
                    _target=$(replay_target "$_sess") || _target=""
                    [ -n "$_target" ] && [ "$_cur" != "$_target" ] && _need_reload=1
                    ;;
            esac
        fi
        if [ "$_need_reload" = "1" ]; then
            if [ -z "${_target:-}" ]; then
                _target=$(replay_target "$_sess") || _target=""
            fi
            if [ -n "$_target" ]; then
                mpv_cmd "{\"command\":[\"loadfile\",\"$_target\",\"replace\"]}" >/dev/null
                mpv_cmd '{"command":["set_property","pause",false]}'            >/dev/null
                # If the new target is the same file mpv just hit EOF on,
                # `loadfile replace` can be a quiet no-op on some mpv
                # configurations — explicit seek 0 forces start-from-zero.
                mpv_cmd '{"command":["seek",0,"absolute"]}'                     >/dev/null
            elif [ -n "$_cur" ]; then
                # No clip found for this session, but mpv has something loaded —
                # cycle pause on it so Space still gives audible feedback rather
                # than silently breaking. Popup will surface "(no clip for
                # session: X)" via its load-pending timer.
                mpv_cmd '{"command":["cycle","pause"]}' >/dev/null
            fi
            # else: idle and no clip — nothing to do. Popup shows the
            #       "(no clip for session: X)" message after 2s.
        else
            mpv_cmd '{"command":["cycle","pause"]}' >/dev/null
        fi
        ;;
    replay)
        if target=$(replay_target "${2:-}") && [ -n "$target" ]; then
            mpv_cmd "{\"command\":[\"loadfile\",\"$target\",\"replace\"]}" >/dev/null
            mpv_cmd '{"command":["set_property","pause",false]}'           >/dev/null
            # See comment in `toggle`: explicit seek 0 ensures we always
            # start from the beginning even when mpv was at EOF on the
            # same file we just loaded.
            mpv_cmd '{"command":["seek",0,"absolute"]}'                    >/dev/null
        fi
        # else: no clip for this session — silent no-op, popup surfaces it.
        ;;
    seek)    mpv_cmd "{\"command\":[\"seek\",${2:-5},\"relative\"]}"   >/dev/null ;;
    start)   mpv_cmd '{"command":["seek",0,"absolute"]}'               >/dev/null ;;
    volume)  mpv_cmd "{\"command\":[\"add\",\"volume\",${2:-5}]}"      >/dev/null ;;
    mute)    mpv_cmd '{"command":["cycle","mute"]}'                    >/dev/null ;;
    slower)  mpv_cmd '{"command":["multiply","speed",0.9091]}'         >/dev/null ;;
    faster)  mpv_cmd '{"command":["multiply","speed",1.1]}'            >/dev/null ;;
    speed)   mpv_cmd "{\"command\":[\"set_property\",\"speed\",${2:-1}]}" >/dev/null ;;
    prev|next)
        # Walk the session's archive by mtime. Find the currently-loaded
        # clip's position, jump to the older (prev) or newer (next) one.
        direction="$1"
        sess="${2:-}"
        if [ -z "$sess" ] && [ -n "${TMUX_PANE:-}" ]; then
            sess=$(tmux display-message -p -t "$TMUX_PANE" '#{session_name}' 2>/dev/null)
        fi
        [ -z "$sess" ] && exit 1
        sslug=$(slug "$sess")
        cur=$(mpv_get path)
        cur_base="${cur##*/}"
        # Resolve symlinks (mpv may report `latest--<...>.mp3`) to a real
        # archive filename so we can locate it in the mtime-sorted list.
        if [ -d "$ARCHIVE_DIR" ]; then
            [ -L "$cur" ] && cur_base=$(basename "$(readlink -f "$cur")")
            files=$(ls -tr "$ARCHIVE_DIR"/*--"${sslug}"__*.{wav,mp3,opus,ogg} 2>/dev/null)
        else
            # shellcheck disable=SC2086
            files=$(ssh ${TTS_SSH_DEFAULTS} ${CLAUDE_TTS_SSH_OPTS:-} "$PHONE_HOST" \
                "bash -c 'set +o nullglob; for ext in wav mp3 opus ogg; do for f in $ARCHIVE_DIR/*--${sslug}__*.\$ext; do [ -e \"\$f\" ] && stat -c \"%Y \$f\" \"\$f\" 2>/dev/null; done; done | sort -n | cut -d\" \" -f2-; readlink -f $cur 2>/dev/null'" 2>/dev/null)
            # Last line of output is the readlink-resolved current path.
            resolved=$(printf '%s\n' "$files" | tail -n1)
            files=$(printf '%s\n' "$files" | sed '$d')
            [ -n "$resolved" ] && cur_base="${resolved##*/}"
        fi
        target=""
        found=0
        while IFS= read -r f; do
            [ -z "$f" ] && continue
            base="${f##*/}"
            case "$direction" in
                prev)
                    [ "$base" = "$cur_base" ] && break
                    target="$f"
                    ;;
                next)
                    if [ "$found" = "1" ]; then target="$f"; break; fi
                    [ "$base" = "$cur_base" ] && found=1
                    ;;
            esac
        done <<< "$files"
        if [ -n "$target" ]; then
            mpv_cmd "{\"command\":[\"loadfile\",\"$target\",\"replace\"]}" >/dev/null
            mpv_cmd '{"command":["set_property","pause",false]}'           >/dev/null
            mpv_cmd '{"command":["seek",0,"absolute"]}'                    >/dev/null
        fi
        ;;
    status)
        # One IPC round-trip for all five properties.
        mapfile -t _vals < <(mpv_batch_get pause idle-active time-pos duration volume)
        paused="${_vals[0]:-}"
        idle="${_vals[1]:-}"
        pos="${_vals[2]:-}"
        dur="${_vals[3]:-}"
        vol="${_vals[4]:-}"
        if [ "$idle" = "true" ] || [ -z "$paused" ]; then
            state="○ idle"
        elif [ "$paused" = "true" ]; then
            state="⏸  PAUSED"
        else
            state="▶  PLAYING"
        fi
        printf '%s  %s/%s  vol=%s\n' \
            "$state" "$(fmt_time "$pos")" "$(fmt_time "$dur")" "${vol%.*}"
        ;;
    nowplaying)
        mpv_get path
        ;;
    get)
        # Bulk getter — one IPC round-trip, one line per prop (empty if unavailable).
        shift
        [ $# -gt 0 ] || { echo "tts-ctl get: needs at least one property" >&2; exit 2; }
        mpv_batch_get "$@"
        ;;
    *)
        echo "Usage: tts-ctl pause|resume|toggle|replay [session]|seek SECS|start|volume DELTA|mute|slower|faster|speed N|status|nowplaying|get PROP..." >&2
        exit 1
        ;;
esac
