#!/bin/bash
# aar-music-where — choose which hosts play the AAR music stream.
#
# Each known host runs a small mpv consumer (mpv-music-aar) that pulls
# http://mel:7772/sink.mp3 — the output of the aar-music sink. Starting
# the consumer = the host joins the room. Stopping it = leaves.
#
# Hosts are defined in ~/.config/agent-audio-relay/music-where.json:
#
#   {
#     "hosts": {
#       "phone": {
#         "ssh":    "p8ar",
#         "start":  "SVDIR=$PREFIX/var/service sv up mpv-music-aar",
#         "stop":   "SVDIR=$PREFIX/var/service sv down mpv-music-aar",
#         "status": "SVDIR=$PREFIX/var/service sv status mpv-music-aar"
#       },
#       "homer": {
#         "ssh":    "homer",
#         "start":  "systemctl --user start mpv-music-aar",
#         "stop":   "systemctl --user stop mpv-music-aar",
#         "status": "systemctl --user is-active mpv-music-aar"
#       }
#     }
#   }
#
# Usage:
#   aar-music-where list                  # show current state per host
#   aar-music-where add <host>            # join host
#   aar-music-where remove <host>         # leave host
#   aar-music-where only <host>           # join host, leave all others
#
# `host` is the JSON key (e.g. "phone"), not the ssh alias.

set -euo pipefail

CONFIG="${AAR_MUSIC_WHERE_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/agent-audio-relay/music-where.json}"

die()  { echo "aar-music-where: $*" >&2; exit 1; }
have() { command -v "$1" >/dev/null 2>&1; }

if ! have jq; then
    die "jq is required (Fedora: dnf install jq, Debian: apt install jq)"
fi

if [ ! -f "$CONFIG" ]; then
    die "config not found: $CONFIG (see header for example schema)"
fi

field() {
    # $1=host  $2=field
    jq -r --arg h "$1" --arg f "$2" '.hosts[$h][$f] // empty' "$CONFIG"
}

hosts() {
    jq -r '.hosts | keys[]' "$CONFIG"
}

ssh_for() {
    local v
    v=$(field "$1" ssh)
    [ -z "$v" ] && die "unknown host: $1 (known: $(hosts | tr '\n' ' '))"
    echo "$v"
}

run_remote() {
    # $1=host-key  $2=field  $3=label-on-error
    local host sshhost cmd
    host="$1"
    sshhost=$(ssh_for "$host")
    cmd=$(field "$host" "$2")
    [ -z "$cmd" ] && die "host '$host' has no '$2' command"
    if ! ssh -o BatchMode=yes -o ConnectTimeout=10 "$sshhost" "$cmd"; then
        echo "aar-music-where: ${3:-$2} failed for $host ($sshhost)" >&2
        return 1
    fi
}

cmd_add() {
    local h="${1:?host}"
    run_remote "$h" start "start"
    echo "aar-music-where: $h → playing"
}

cmd_remove() {
    local h="${1:?host}"
    run_remote "$h" stop "stop"
    echo "aar-music-where: $h → silent"
}

cmd_only() {
    local target="${1:?host}"
    ssh_for "$target" >/dev/null  # validate before we start stopping others
    local h
    for h in $(hosts); do
        if [ "$h" = "$target" ]; then
            cmd_add "$h"
        else
            cmd_remove "$h" || true
        fi
    done
}

cmd_list() {
    local h sshhost cmd state
    printf "%-12s %-10s %s\n" "HOST" "SSH" "STATE"
    for h in $(hosts); do
        sshhost=$(ssh_for "$h")
        cmd=$(field "$h" status)
        if [ -z "$cmd" ]; then
            state="(no status command configured)"
        else
            state=$(ssh -o BatchMode=yes -o ConnectTimeout=5 "$sshhost" "$cmd" 2>&1 | head -1 || true)
            [ -z "$state" ] && state="(unreachable)"
        fi
        printf "%-12s %-10s %s\n" "$h" "$sshhost" "$state"
    done
}

usage() {
    sed -n '2,/^$/p' "$0" | sed 's/^# \?//' >&2
    exit 1
}

case "${1:-}" in
    list|status)         shift; cmd_list "$@" ;;
    add|join)            shift; cmd_add "$@" ;;
    remove|leave|stop)   shift; cmd_remove "$@" ;;
    only)                shift; cmd_only "$@" ;;
    -h|--help|help|"")   usage ;;
    *) die "unknown subcommand: $1 (try: list, add, remove, only)" ;;
esac
