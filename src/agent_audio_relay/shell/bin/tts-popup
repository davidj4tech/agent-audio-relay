#!/bin/bash
# Interactive tts-popup — meant to run inside `tmux display-popup -E`.
# Designed as a tiny top-right key-capture overlay paired with the
# status-line in tmux's status-right (which shows the progress bar).
# The popup itself just shows the session and current state, and exists
# mostly to put tmux in a key-capture mode for the duration. Suggested
# tmux binding: `display-popup -E -w 20 -h 3 -x R -y 0`.
#
#   ▶ aar
#
# Single-key hotkeys (no on-screen hints — keep popup compact; see README):
#   Space   toggle play/pause
#   r       replay (current tmux session)
#   0       seek to start of current clip
#   h / l   seek -5s / +5s
#   H / L   seek -30s / +30s
#   - / =   volume -5 / +5
#   m       toggle mute
#   [ / ]   slower / faster (speed × 1/1.1 / × 1.1)
#   ?       show keymap in tmux status line
#   q / Esc close
#
# Auto-closes TTS_POPUP_AUTO_CLOSE seconds after playback ends (default 10;
# set to 0 to disable). Only arms after we've observed mpv playing at least
# once, so opening the popup while idle doesn't insta-close.
set -u
TTS_CTL="${TTS_CTL:-tts-ctl}"

# Hide the cursor while the popup runs — without this the terminal cursor
# briefly visible at top-left between frames reads as flicker. Restored
# in _cleanup on EXIT.
printf '\033[?25l'

# Help text for the `?` hotkey. Written to a tempfile at startup so the
# `?` binding can `cat` it inside a nested tmux popup without inline
# heredoc quoting hell. Cleaned up in _cleanup.
HELP_FILE=$(mktemp -t tts-popup-help.XXXXXX)
cat > "$HELP_FILE" <<'EOF'
 TTS popup hotkeys
 ─────────────────
   Space    play/pause; replay if clip
            ended or different session
            is loaded
   r        replay latest for session
   0        seek to start (no reload)
   h / l    seek -5s / +5s
   H / L    seek -30s / +30s
   - / =    volume -5 / +5
   m        toggle mute
   ?        this help
   q / Esc  close popup

 Status bar shows live progress.

 press Esc to dismiss this help
EOF

# Pin the popup to a specific tmux session so toggle/replay always target
# this session's clip — never the global `latest` symlink, which on a shared
# phone archive may point at some other host's session. The tmux binding
# passes the session in via TTS_POPUP_SESSION; if missing we try to recover
# from the inherited TMUX env, but the binding is the reliable path.
SESSION="${TTS_POPUP_SESSION:-}"
# Defensive: tmux's `display-popup` (unlike `run-shell`) doesn't format-
# expand its shell-command argument, so a binding like
#     display-popup -E "TTS_POPUP_SESSION='#{session_name}' tts-popup"
# would pass the literal string `#{session_name}` through. Strip it.
case "$SESSION" in
    *'#{'*) SESSION="" ;;
esac
if [ -z "$SESSION" ] && [ -n "${TMUX:-}" ]; then
    SESSION=$(tmux display-message -p '#S' 2>/dev/null || true)
fi

# When the mpv-tts socket isn't local, every tts-ctl keypress otherwise
# pays a fresh ssh handshake. If the user's ssh config already provides
# a working ControlMaster for the phone host, reuse it (do nothing).
# Otherwise open one for the popup's lifetime.
# Socket auto-discovery (mirrors tts-ctl): prefer an explicit MPV_TTS_SOCK,
# otherwise the tunnel socket from `aar-mpv-tunnel` if present, otherwise
# the on-phone Termux path. When the tunnel socket exists locally, the
# rest of this block (ad-hoc ControlMaster setup) is unnecessary.
_default_local_sock="${XDG_STATE_HOME:-$HOME/.local/state}/agent-audio-relay/mpv-tts.sock"
if [ -n "${MPV_TTS_SOCK:-}" ]; then
    _SOCK="$MPV_TTS_SOCK"
elif [ -S "$_default_local_sock" ]; then
    _SOCK="$_default_local_sock"
else
    _SOCK="/data/data/com.termux/files/usr/tmp/mpv-tts.sock"
fi
_CTL_DIR=""
_CTL_PATH=""
_PHONE_HOST=""
if [ ! -S "$_SOCK" ]; then
    _PHONE_HOST="${CLAUDE_TTS_PHONE_HOST:-p8ar}"
    if ! ssh -o BatchMode=yes -O check "$_PHONE_HOST" 2>/dev/null; then
        _CTL_DIR="$(mktemp -d -t tts-popup.XXXXXX)"
        _CTL_PATH="$_CTL_DIR/ssh.sock"
        if ssh -M -N -f \
                -o ControlPath="$_CTL_PATH" \
                -o ControlPersist=60 \
                -o BatchMode=yes \
                "$_PHONE_HOST" 2>/dev/null \
            && [ -S "$_CTL_PATH" ]; then
            export CLAUDE_TTS_SSH_OPTS="-o ControlPath=$_CTL_PATH"
        else
            rm -rf "$_CTL_DIR"
            _CTL_DIR=""; _CTL_PATH=""
        fi
    fi
fi
# Single EXIT trap below also tears down the ssh ControlMaster (if any).

fmt_time() {
    local t="$1"
    if [ -z "$t" ] || [ "$t" = "null" ]; then
        printf -- '--:--'
        return
    fi
    awk -v t="$t" 'BEGIN{ s=int(t); printf "%02d:%02d", s/60, s%60 }'
}

# Path → display label. Handles every shape mpv may report:
#   latest.<ext>                                      → "global"
#   latest--<host>--<session>.<ext>                   → "<session>"
#   latest--<session>.<ext>                           → "<session>"
#   latest--<session>__<agent>.<ext>                  → "<session>"
#   <ts>--<host>--<session>__<persona>_<agent>_...    → "<session>"
#   <ts>--<session>__<persona>_<agent>_<kind>.<ext>   → "<session>"  (legacy)
#   anything else                                     → basename, no ext
nowplaying_label() {
    local path="$1" base left session
    [ -z "$path" ] || [ "$path" = "null" ] && { printf '(idle)'; return; }
    base="${path##*/}"
    base="${base%.*}"
    if [ "$base" = "latest" ]; then
        printf 'global'
        return
    fi
    # Strip everything from `__` onward (persona/agent/kind), then take
    # the last `--` segment. Works for both `latest--…--<session>` symlinks
    # and raw `<ts>--…--<session>__…` archive filenames.
    left="${base%%__*}"
    session="${left##*--}"
    if [ -n "$session" ] && [ "$session" != "$base" ]; then
        printf '%s' "$session"
    else
        printf '%s' "$base"
    fi
}

bar() {
    local pos="$1" dur="$2" width="$3" filled empty pad fill rest
    if [ -z "$pos" ] || [ -z "$dur" ] || [ "$pos" = "null" ] || [ "$dur" = "null" ]; then
        printf -v pad '%*s' "$width" ''
        printf '%s' "${pad// /─}"
        return
    fi
    filled=$(awk -v p="$pos" -v d="$dur" -v w="$width" \
        'BEGIN{ if(d<=0){print 0; exit} f=int((p/d)*w); if(f<0)f=0; if(f>w)f=w; print f }')
    empty=$((width - filled))
    fill="" rest=""
    if [ "$filled" -gt 0 ]; then
        printf -v pad '%*s' "$filled" ''
        fill="${pad// /█}"
    fi
    if [ "$empty" -gt 0 ]; then
        printf -v pad '%*s' "$empty" ''
        rest="${pad// /░}"
    fi
    printf '%s%s' "$fill" "$rest"
}

# draw() exports IDLE as a side-effect so the main loop can drive the
# auto-close timer without a second IPC round-trip.
IDLE=
_LAST_FRAME=""
draw() {
    # Build the full frame in a buffer and write atomically below.
    local paused idle pos dur vol path mute state cols barw
    # Read whatever the background fetcher most recently wrote. Stays
    # non-blocking so keypresses are never gated on an in-flight ssh RTT.
    if [ -s "$STATE_FILE" ]; then
        mapfile -t STATE < "$STATE_FILE"
    fi
    paused="${STATE[0]:-}"; idle="${STATE[1]:-}"; pos="${STATE[2]:-}"
    dur="${STATE[3]:-}";    vol="${STATE[4]:-}";  path="${STATE[5]:-}"
    mute="${STATE[6]:-}"
    local fetch_ts="${STATE[7]:-}"
    IDLE="$idle"
    # Interpolate time-pos between fetches so the progress bar moves
    # smoothly. Only when actively playing — paused/idle/eof should hold.
    if [ -n "$pos" ] && [ "$pos" != "null" ] \
        && [ -n "$fetch_ts" ] \
        && [ "$paused" = "false" ] && [ "$idle" = "false" ]; then
        pos=$(awk -v p="$pos" -v t="$fetch_ts" -v now="$(date +%s.%N)" -v d="${dur:-0}" \
            'BEGIN{
                p = p + (now - t);
                if (d > 0 && p > d) p = d;
                printf "%.3f", p;
            }')
    fi
    # Compact state glyph (one cell) so the popup line stays one-row.
    if [ "$idle" = "true" ] || [ -z "$paused" ]; then
        state='○'
    elif [ "$paused" = "true" ]; then
        state='⏸'
    else
        state='▶'
    fi
    # No bar inside the popup — the progress bar lives in tmux's
    # status-right via tts-status-line. Popup is just a key-capture
    # overlay, kept tiny so it doesn't visually compete with the
    # status bar.
    :

    # Detect "we asked mpv to load and nothing happened" so the user knows
    # Space did something — without it, a session that has no clip on the
    # phone looks identical to Space being broken.
    local label
    if [ -n "${LOAD_PENDING_SINCE:-}" ]; then
        if [ "$idle" != "true" ] && [ -n "$idle" ]; then
            LOAD_PENDING_SINCE=  # mpv started a clip; clear pending state
        elif [ $((SECONDS - LOAD_PENDING_SINCE)) -ge 2 ]; then
            label="(no clip for session: ${SESSION:-?})"
        fi
    fi
    if [ -z "${label:-}" ]; then
        if [ -z "$path" ] || [ "$path" = "null" ]; then
            # mpv is idle — surface the session this popup is pinned to so
            # the user knows what Space-after-idle will load.
            [ -n "$SESSION" ] && label="(idle: $SESSION)" || label="(idle)"
        else
            label=$(nowplaying_label "$path")
        fi
    fi
    local mute_suffix=""
    [ "$mute" = "true" ] && mute_suffix=' [M]'
    # Build the whole frame in one buffer and emit with a single printf.
    # tmux's popup renderer applies the entire write atomically, so the
    # user never sees the bar half-drawn or the label arrive before the
    # state line — eliminates the visible flicker. \033[K (erase to EOL)
    # keeps prior-frame residue from leaking past shorter new content;
    # \033[J at the bottom wipes anything below the current frame.
    # One-line layout. \033[K erases any prior-frame residue; \033[J
    # below wipes anything that was drawn on lines 2+ by an older popup.
    local frame=$'\033[H'
    frame+="${state} ${label}${mute_suffix}"
    frame+=$'\033[K\033[J'
    # Only emit if the rendered output changed. Bar cells only cross a
    # boundary every ~(duration/width) seconds, but draw() runs every
    # TICK (~0.15s) — without this gate we'd repaint identical frames
    # 6-7×/sec, which the terminal renders as visible flicker on the
    # bar cells. Comparing the whole frame string is cheap (no fork).
    if [ "$frame" != "$_LAST_FRAME" ]; then
        printf '%s' "$frame"
        _LAST_FRAME="$frame"
    fi
}

REFRESH="${TTS_POPUP_REFRESH:-0.5}"   # how often the background fetcher polls mpv
TICK="${TTS_POPUP_TICK:-0.15}"        # main-loop keypress timeout (UI responsiveness floor)
AUTO_CLOSE_IDLE="${TTS_POPUP_AUTO_CLOSE:-10}"

# Auto-close state: only fire after we've actually seen mpv playing, so
# opening the popup while idle doesn't insta-close.
EVER_PLAYED=0
IDLE_SINCE=

# Set by Space/r when we expect mpv to start playing. Cleared by draw()
# once mpv reports non-idle. If still idle 2s later, draw() shows
# "(no clip for session: ...)" so the user sees Space did *something*.
LOAD_PENDING_SINCE=

# State cache shared with the background fetcher. The fetcher does the
# slow ssh+IPC round-trip (~700ms over Tailscale to the phone) while the
# main loop reads stale-but-cached state non-blockingly — keypress
# response is gated on $TICK (~150ms), not on the IPC RTT.
STATE_FILE=$(mktemp -t tts-popup-state.XXXXXX)
declare -a STATE

# Refetch state out-of-band. Used both by the periodic fetcher and as a
# kick after every keypress (so the display updates promptly once the
# action's effect lands on mpv, instead of waiting for the next REFRESH).
# Appends a fetch-time epoch so draw() can interpolate time-pos between
# fetches and the progress bar moves smoothly instead of jumping once
# per REFRESH.
_refetch_state() {
    {
        "$TTS_CTL" get pause idle-active time-pos duration volume path mute \
            && date +%s.%N
    } > "$STATE_FILE.tmp" 2>/dev/null \
        && mv -f "$STATE_FILE.tmp" "$STATE_FILE" 2>/dev/null
}

# Background fetcher: writes one full state snapshot per REFRESH seconds.
(
    while true; do
        _refetch_state
        sleep "$REFRESH"
    done
) &
FETCH_PID=$!

_cleanup() {
    # Restore cursor visibility (we hid it at startup to avoid mid-frame
    # cursor blink showing as flicker).
    printf '\033[?25h'
    kill "$FETCH_PID" 2>/dev/null
    rm -f "$STATE_FILE" "$STATE_FILE.tmp" "$HELP_FILE"
    if [ -n "$_CTL_PATH" ] && [ -S "$_CTL_PATH" ]; then
        ssh -O exit -o ControlPath="$_CTL_PATH" "$_PHONE_HOST" 2>/dev/null
    fi
    [ -n "$_CTL_DIR" ] && rm -rf "$_CTL_DIR"
}
trap _cleanup EXIT

# Block briefly for the first snapshot so the very first frame isn't blank.
for _ in 1 2 3 4 5 6 7 8; do
    [ -s "$STATE_FILE" ] && break
    sleep 0.1
done

while true; do
    draw
    # Auto-close bookkeeping (uses $IDLE set as a side-effect of draw).
    if [ "$IDLE" != "true" ] && [ -n "$IDLE" ]; then
        EVER_PLAYED=1
        IDLE_SINCE=
    elif [ "$IDLE" = "true" ] && [ "$EVER_PLAYED" = "1" ]; then
        : "${IDLE_SINCE:=$SECONDS}"
        if [ "$AUTO_CLOSE_IDLE" -gt 0 ] \
            && [ $((SECONDS - IDLE_SINCE)) -ge "$AUTO_CLOSE_IDLE" ]; then
            exit 0
        fi
    fi

    # Short keypress timeout — keypresses respond within ~$TICK, completely
    # decoupled from the background fetcher's IPC RTT. Empty key on timeout
    # just falls through to redraw.
    IFS= read -r -s -n1 -t "$TICK" key
    rc=$?
    # rc=0: key pressed; rc>128: timeout (redraw); rc=1 with empty: stdin closed.
    if [ $rc -gt 128 ]; then
        continue
    elif [ $rc -ne 0 ]; then
        break
    fi
    # All actions fire in the background so the keypress loop never blocks
    # on an ssh RTT. The next periodic fetch (or the explicit refetch below)
    # picks up the resulting state change.
    case "$key" in
        ' ') "$TTS_CTL" toggle "$SESSION" >/dev/null 2>&1 & disown
             LOAD_PENDING_SINCE=$SECONDS ;;
        r)   "$TTS_CTL" replay "$SESSION" >/dev/null 2>&1 & disown
             LOAD_PENDING_SINCE=$SECONDS ;;
        0)   "$TTS_CTL" start    >/dev/null 2>&1 & disown ;;
        h)   "$TTS_CTL" seek -5  >/dev/null 2>&1 & disown ;;
        l)   "$TTS_CTL" seek 5   >/dev/null 2>&1 & disown ;;
        H)   "$TTS_CTL" seek -30 >/dev/null 2>&1 & disown ;;
        L)   "$TTS_CTL" seek 30  >/dev/null 2>&1 & disown ;;
        '-') "$TTS_CTL" volume -5 >/dev/null 2>&1 & disown ;;
        '=') "$TTS_CTL" volume 5  >/dev/null 2>&1 & disown ;;
        m)   "$TTS_CTL" mute     >/dev/null 2>&1 & disown ;;
        '[') "$TTS_CTL" slower   >/dev/null 2>&1 & disown ;;
        ']') "$TTS_CTL" faster   >/dev/null 2>&1 & disown ;;
        '?')
            # Help via tmux's display-message. Nested display-popup from
            # inside an existing popup gets refused/killed instantly on at
            # least some tmux versions (we logged display-popup exit=0
            # within milliseconds even with `tail -f /dev/null`). display-
            # message shows in the status area without nesting and with no
            # geometry constraints. -d 0 means "stay until cleared by next
            # status update" (which happens within status-interval).
            tmux display-message -d 7000 \
                "tts: Space=togl r=replay 0=start h/l=±5s H/L=±30s -/=vol m=mute [/]=speed q=quit" \
                2>/dev/null
            ;;
        q|$'\e') exit 0 ;;
        *)   continue ;;
    esac
    # Kick an out-of-band refetch ~$REFRESH seconds before the next periodic
    # one would fire, so the visible state updates promptly after an action
    # lands on mpv (~700ms RTT after backgrounded action started).
    ( sleep 0.8; _refetch_state ) & disown
    # Any user activity rearms the idle timer.
    IDLE_SINCE=
done
