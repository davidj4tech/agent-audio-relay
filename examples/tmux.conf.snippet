# agent-audio-relay tmux bindings
# Source from your tmux config:
#     source-file ~/path/to/agent-audio-relay/examples/tmux.conf.snippet
#
# `prefix T` enters the `tts` key table; subsequent keys:
#   t      → interactive popup (one-line; hotkeys: Space toggle, r replay,
#            0 start, h/l ±5s, H/L ±30s, -/= vol, m mute, q close)
#   Space  → toggle play/pause (one-shot)
#   r      → replay latest from current tmux session

bind T switch-client -T tts
# Tiny key-capture popup pinned to the top-right corner. The progress bar
# itself lives in tmux's status-right via tts-status-line, so the popup
# only needs to capture key events. -w 22 -h 3 is the smallest tmux popup
# that fits the `▶ <session>` indicator with default border. -x R -y 0
# anchors top-right.
bind -T tts t     display-popup -E -w 22 -h 3 -x R -y 0 "TTS_POPUP_SESSION='#{session_name}' ~/.local/bin/tts-popup"
bind -T tts Space run-shell "~/.local/bin/tts-ctl toggle '#{session_name}'"
bind -T tts r     run-shell "~/.local/bin/tts-ctl replay '#{session_name}'"
